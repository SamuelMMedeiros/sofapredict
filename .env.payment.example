# ============================================================================
# PAYMENT GATEWAY CONFIGURATION
# ============================================================================

# PIX Payment (via Asaas)
# Get your API key from: https://asaas.com/api
ASAAS_API_KEY=your_asaas_api_key_here
ASAAS_WEBHOOK_SECRET=your_asaas_webhook_secret

# Credit Card Payment (via Stripe)
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal Payment
# Get your credentials from: https://developer.paypal.com/dashboard
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox # or 'live' for production

# Telegram Stars Payment
# Get your bot token from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Encryption
# Generate a secure key: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=your_encryption_master_key_here

# Application URL (for webhooks and redirects)
APP_URL=https://your-domain.com

# ============================================================================
# SUBSCRIPTION DEFAULTS
# ============================================================================

# Free tier limits
FREE_TIER_MAX_TEAMS=1
FREE_TIER_MAX_BETS=5

# Pro tier limits
PRO_TIER_MAX_TEAMS=5
PRO_TIER_MAX_BETS=50

# Premium tier limits
PREMIUM_TIER_MAX_TEAMS=10
PREMIUM_TIER_MAX_BETS=200

# ============================================================================
# PAYMENT SETTINGS
# ============================================================================

# Currency (default: BRL for Brazilian Real)
DEFAULT_CURRENCY=BRL

# Tax rate (if applicable)
TAX_RATE=0.15

# Webhook retry attempts
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5000 # milliseconds
